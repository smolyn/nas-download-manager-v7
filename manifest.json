{
  "manifest_version": 3,
  "name": "NAS Download Manager (Synology DSM 7+)",
  "version": "0.8.0",
  "description": "__MSG_Add_and_manage_Download_Station_tasks_on_your_Synology_DiskStation__",
  "default_locale": "en",
  "browser_specific_settings": {
    "gecko": {
      "id": "nas-download-manager-dsm7@smolyn.org",
      "strict_min_version": "148.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  },
  "permissions": ["contextMenus", "storage", "notifications", "alarms"],
  "host_permissions": ["<all_urls>"],
  "optional_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["dist/content/index.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "dist/background/index.js",
    "scripts": ["dist/background/index.js"]
  },
  "action": {
    "default_title": "NAS Download Manager",
    "default_popup": "html/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "64": "icons/icon-64.png",
      "128": "icons/icon-128.png",
      "256": "icons/icon-256.png"
    }
  },
  "options_ui": {
    "page": "html/settings.html",
    "open_in_tab": false
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "64": "icons/icon-64.png",
    "128": "icons/icon-128.png",
    "256": "icons/icon-256.png"
  }
}
