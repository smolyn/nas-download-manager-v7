{
  "name": "nas-download-manager-v3",
  "version": "0.0.0",
  "description": "An open source browser extension for adding/managing download tasks to your Synology DiskStation.",
  "scripts": {
    "build": "node --import tsx build.ts",
    "watch": "node --import tsx build.ts --watch",
    "check": "svelte-check && tsc -p src --noEmit",
    "lint": "eslint src/ && prettier --check 'src/**/*' && pnpm check",
    "format": "prettier --write 'src/**/*'",
    "test": "mocha --require tsx 'test/**/*.{ts,tsx}'",
    "zip": "rm -rf addon.zip && zip -r addon.zip dist html icons _locales manifest.json -x '**/*.map' -x '**/.DS_Store'",
    "zip-sources": "rm -rf sources.zip && zip -r sources.zip . -x '*.zip' -x 'dist/*' -x 'node_modules/*' -x '**/.DS_Store' -x '.git/*' -x '.cache/*' -x '.vscode/*' -x '.github/*' -x '.circleci/*'"
  },
  "type": "module",
  "license": "MIT",
  "browserslist": [
    "chrome >= 146",
    "firefox >= 148"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/firefox-webext-browser": "143.0.0",
    "@types/mocha": "^10.0.10",
    "chai": "^6.2.2",
    "eslint": "^10.1.0",
    "eslint-plugin-svelte": "^3.16.0",
    "mocha": "^11.7.5",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.55.1",
    "svelte-check": "^4.4.6",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.3"
  },
  "packageManager": "pnpm@10.12.1"
}
